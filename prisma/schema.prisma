generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth Models (NextAuth v5 / @auth/prisma-adapter) ────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phone         String?
  college       String?
  instagram     String?
  facebook      String?
  role          String    @default("user") // "user" | "admin"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  registrations TripRegistration[]
  contactMsgs   ContactMessage[]

  @@index([email])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

// ─── Core Domain Models ───────────────────────────────────────────────────────

model Trip {
  id          String   @id @default(cuid())
  name        String
  destination String
  description String
  price       Int      @default(0)
  // "completed" | "coming_soon" | "booking_open" | "yet_to_announce"
  status      String   @default("yet_to_announce")
  startDate   String?
  endDate     String?
  totalSlots  Int      @default(30)
  bookedSlots Int      @default(0)
  imageUrl    String?
  featured    Boolean  @default(false)
  category    String?  // "mountain" | "beach" | "culture" | "adventure" — for filtering
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  registrations TripRegistration[]

  @@index([status])
  @@index([featured])
  @@index([category])
  @@index([createdAt])
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  content   String
  author    String   @default("Safarnama Team")
  tripName  String?
  imageUrl  String?
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published])
  @@index([createdAt])
}

model GalleryPhoto {
  id        String   @id @default(cuid())
  url       String
  caption   String?
  tripName  String
  category  String?  // mirrors Trip.category for gallery filtering
  createdAt DateTime @default(now())

  @@index([tripName])
  @@index([category])
  @@index([createdAt])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  message   String
  // "info" | "success" | "warning" | "urgent"
  type      String   @default("info")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([active])
}

model TripRegistration {
  id       String   @id @default(cuid())
  userId   String?
  name     String
  email    String
  phone    String
  college  String?
  city     String?
  gender   String?
  age      String?
  tripId   String?  // FK to Trip for relational integrity (optional for backward compat)
  tripName String
  message  String?
  // "pending" | "confirmed" | "cancelled"
  status   String   @default("pending")
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
  trip Trip? @relation(fields: [tripId], references: [id])

  @@index([userId])
  @@index([tripId])
  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model ContactMessage {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  email     String
  subject   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}
